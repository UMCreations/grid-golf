{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://puzzlegolf.local/schemas/level.schema.json",
  "title": "PuzzleGolf Level",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "mode",
    "difficulty",
    "width",
    "height",
    "startPosition",
    "holePosition",
    "levelPar",
    "tiles"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["Classic", "Adventure"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["Easy", "Medium", "Hard"]
    },
    "width": {
      "type": "integer",
      "minimum": 1
    },
    "height": {
      "type": "integer",
      "minimum": 1
    },
    "startPosition": {
      "$ref": "#/$defs/position"
    },
    "holePosition": {
      "$ref": "#/$defs/position"
    },
    "levelPar": {
      "type": "integer",
      "minimum": 1
    },
    "tiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tile"
      }
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "$defs": {
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": {
          "type": "integer",
          "minimum": 0
        },
        "y": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "tile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "type", "power"],
      "properties": {
        "x": {
          "type": "integer",
          "minimum": 0
        },
        "y": {
          "type": "integer",
          "minimum": 0
        },
        "type": {
          "type": "string",
          "enum": [
            "Standard",
            "Start",
            "Hole",
            "Wall",
            "Water",
            "Ice",
            "Sand",
            "Boost"
          ]
        },
        "power": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "author": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      }
    }
  }
}
