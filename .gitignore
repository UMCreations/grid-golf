# This .gitignore file is optimized for Unity projects following best practices.
# It is designed to work whether your Unity project is at the root or in a subdirectory.

# --- Unity ---
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/
*.log
*.utmp

# Blender backup files
*.blend1
*.blend1.meta

# --- IDEs & Editors ---
# JetBrains Rider
**/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user
.idea/

# Visual Studio
.vs/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# VS Code
.vscode/

# --- Build & CI ---
.gradle/
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
crashlytics-build.properties

# --- Unity Specific Metadata ---
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt
mono_crash.*

# --- Features & Packages ---
# TestRunner
InitTestScene*.unity*
**/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Addressables
/ServerData
**/[Aa]ssets/StreamingAssets/aa*
**/[Aa]ssets/AddressableAssetsData/link.xml*
**/[Aa]ssets/Addressables_Temp*
**/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting
**/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
**/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
**/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
**/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# PlasticSCM
plastic/

# --- OS Specific ---
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
[Dd]esktop.ini

# --- Other ---
*.swp
*~

# --- GitHub Pages WebGL publish exception ---
# Keep general build outputs ignored, but allow the committed WebGL publish build.
!PuzzleGolf/Builds/
!PuzzleGolf/Builds/WebGL/
!PuzzleGolf/Builds/WebGL/**
